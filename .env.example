# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Telefonkonsultation (booking-guiden på forsiden) ---
# Resend API-nøgle (opret gratis på https://resend.com)
RESEND_API_KEY=
# Klinikkens e-mail, som leads sendes til
CONSULTATION_EMAIL_TO=info@skonhedsklinik-aarhus.dk
# Afsender. Kræver et verificeret domæne i Resend.
# Indtil domænet er verificeret, kan Resends delte afsender bruges:
CONSULTATION_EMAIL_FROM="Skønhedsklinik Aarhus <onboarding@resend.dev>"
